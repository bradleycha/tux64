index 0000000..139f5c7
--- /dev/null
+++ b/ares/ares/node/debugger/tracer/dmesg.hpp
@@ -0,0 +1,22 @@
+struct Dmesg : Tracer {
+  DeclareClass(Dmesg, "debugger.tracer.dmesg")
+
+  Dmesg(string name = {}, string component = {}) : Tracer(name, component) {
+    _lineBuffer = {};
+  }
+
+  auto readCharacter(char character) -> void {
+    if(!enabled()) return;
+
+    if(character == '\n') {
+      PlatformLog(std::dynamic_pointer_cast<Tracer>(shared_from_this()), _lineBuffer);
+      _lineBuffer = {};
+      return;
+    }
+    
+    _lineBuffer.append(character);
+  }
+
+protected:
+  string _lineBuffer;
+};
