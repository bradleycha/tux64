   }
 }
+
+auto PI::Debugger::dmesgRead(u32 data) -> void {
+  bool cpu_big = cpu.context.bigEndian();
+  bool host_big;
+
+#if defined(ENDIAN_BIG)
+  host_big = true;
+#else
+  host_big = false;
+#endif
+
+  if(cpu_big != host_big) data >>= 24;
+
+  tracer.dmesg->readCharacter((char)data);
+}
